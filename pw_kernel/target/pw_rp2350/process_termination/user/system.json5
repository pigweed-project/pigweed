{
  arch: {
    type: "armv8m",
    vector_table_start_address: 0x10000000,
    vector_table_size_bytes: 2048,
  },
  kernel: {
    flash_start_address: 0x10000800,
    flash_size_bytes: 261120,
    ram_start_address: 0x20000000,
    ram_size_bytes: 65536,
  },
  apps: [
    {
      name: "process_termination",
      flash_size_bytes: 261120,
      processes: [
        {
          name: "main",
          ram_size_bytes: 65536,
          objects: [
            {
              name: "clean_exit_process",
              type: "process",
              linked_process: "clean_exit",
            },
            {
              name: "forced_exit_process",
              type: "process",
              linked_process: "forced_exit",
            },
            {
              name: "exception_exit_process",
              type: "process",
              linked_process: "exception_exit",
            },
            {
              name: "restart_process",
              type: "process",
              linked_process: "restart",
            },
            {
              name: "ipc_control_initiator",
              type: "channel_initiator",
              handler_process: "restart",
              handler_object_name: "ipc_control_handler",
            },
            {
              name: "ipc_reset",
              type: "channel_handler",
            },
            {
              name: "wait_group",
              type: "wait_group",
            },
            {
              name: "main_thread",
              // Generous stacks size pending kernel stack size optimization.
              kernel_stack_size_bytes: 2048,
              type: "thread",
            },
            {
              name: "test_thread",
              // Generous stacks size pending kernel stack size optimization.
              kernel_stack_size_bytes: 2048,
              type: "thread",
            },
          ],
        },
        {
          name: "clean_exit",
          ram_size_bytes: 65536,
          objects: [
            {
              name: "clean_exit_thread",
              // Generous stacks size pending kernel stack size optimization.
              kernel_stack_size_bytes: 2048,
              type: "thread",
            },
          ],
        },
        {
          name: "forced_exit",
          ram_size_bytes: 65536,
          objects: [
            {
              name: "forced_exit_thread",
              // Generous stacks size pending kernel stack size optimization.
              kernel_stack_size_bytes: 2048,
              type: "thread",
            },
          ],
        },
        {
          name: "restart",
          ram_size_bytes: 65536,
          objects: [
            {
              name: "wait_group",
              type: "wait_group",
            },
            {
              name: "ipc_control_handler",
              type: "channel_handler",
            },
            {
              name: "ipc_reset",
              type: "channel_initiator",
              handler_process: "main",
              handler_object_name: "ipc_reset",
            },
            {
              name: "restart_thread",
              kernel_stack_size_bytes: 2048,
              type: "thread",
            },
          ],
        },
        {
          name: "exception_exit",
          ram_size_bytes: 65536,
          objects: [
            {
              name: "exception_exit_thread",
              // Generous stacks size pending kernel stack size optimization.
              kernel_stack_size_bytes: 2048,
              type: "thread",
            },
          ],
        },
      ],
    },
  ],
}