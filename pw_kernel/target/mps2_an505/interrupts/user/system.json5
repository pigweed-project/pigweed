{
  arch: {
    type: "armv8m",
    vector_table_start_address: 0x10000000,
    vector_table_size_bytes: 2048,
  },
  kernel: {
    flash_start_address: 0x10000800,
    flash_size_bytes: 261120,
    ram_start_address: 0x38000000,
    ram_size_bytes: 65536,
  },
  apps: [
    {
      name: "test_interrupts",
      flash_size_bytes: 261120,
      processes: [
        {
          name: "interrupt",
          ram_size_bytes: 65536,
          objects: [
            {
              name: "ipc",
              type: "channel_handler",
            },
            {
              name: "interrupt_thread",
              // Generous stacks size pending kernel stack size optimization.
              kernel_stack_size_bytes: 2048,
              type: "thread",
            },
          ],
        },
      ],
      constants: [
        {
          name: "test_irq",
          ram_size_bytes: 65536,
          type: "u32",
          value: 42
        },
        {
          name: "test_irq2",
          ram_size_bytes: 65536,
          type: "u32",
          value: 43
        },

      ],
    },
    {
      name: "test_interrupt_listener",
      flash_size_bytes: 261120,
      processes: [
        {
          name: "listener",
          ram_size_bytes: 65536,
          objects: [
            {
              name: "test_interrupts",
              type: "interrupt",
              irqs: [
                {
                  name: "test_irq",
                  number: 42,
                },
                {
                  name: "test_irq2",
                  number: 43,
                }
              ]
            },
            {
              name: "interrupt_wait_group",
              type: "wait_group",
            },
            {
              name: "ipc",
              type: "channel_initiator",
              handler_process: "interrupt",
              handler_object_name: "ipc",
            },
            {
              name: "interrupt_thread",
              // Generous stacks size pending kernel stack size optimization.
              kernel_stack_size_bytes: 2048,
              type: "thread",
            },
          ],
        },
      ],
    },
  ],
}
