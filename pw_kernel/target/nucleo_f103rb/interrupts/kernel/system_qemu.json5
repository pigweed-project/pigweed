{
  // Memory addresses match QEMU mps2-an385 Cortex-M3 machine.
  // For physical Nucleo-F103RB hardware, see system.json5.
  arch: {
    type: "armv7m",
    vector_table_start_address: 0x00000000,
    vector_table_size_bytes: 2048,
  },
  kernel: {
    flash_start_address: 0x00000800,
    flash_size_bytes: 129024,
    ram_start_address: 0x20000000,
    ram_size_bytes: 20480,
    // NOTE: mps2-an385 only implements 32 external NVIC lines (0-31),
    // unlike real STM32F103RB hardware (43 lines). See target.rs for
    // details. Do not raise this above 31.
    interrupt_table: {
      table: {
        "31": "test_interrupts::test_interrupt_handler",
      }
    },
  },
}
