{
  // STM32F103RB native memory addresses for physical hardware.
  arch: {
    type: "armv7m",
    vector_table_start_address: 0x08000000,
    vector_table_size_bytes: 2048,
  },
  kernel: {
    flash_start_address: 0x08000800,
    flash_size_bytes: 129024,
    ram_start_address: 0x20000000,
    ram_size_bytes: 20480,
    interrupt_table: {
      table: {
        "42": "test_interrupts::test_interrupt_handler",
      }
    },
  },
}
