{
  arch: {
    type: "riscv",
  },
  kernel: {
    flash_start_address: 0x80000000,
    flash_size_bytes: 261120,
    ram_start_address: 0x81000000,
    ram_size_bytes: 65536,
    interrupt_table: {
      table: {}
    },
  },
  apps: [
    {
      name: "main",
      flash_size_bytes: 261120,
      processes: [
        {
          name: "test_process",
          ram_size_bytes: 65536,
          objects: [
            { name: "forced_exit_process", type: "process", linked_process: "forced_exit" },
            {
              name: "main_thread",
              kernel_stack_size_bytes: 2048,
              type: "thread",
              main_thread: true,
            },
            {
              name: "test_thread",
              kernel_stack_size_bytes: 2048,
              type: "thread",
            },
          ],
        },
      ],
    },
    {
      name: "forced_exit",
      flash_size_bytes: 261120,
      processes: [
        {
          name: "forced_exit",
          ram_size_bytes: 65536,
          objects: [
            {
              name: "forced_exit_thread",
              kernel_stack_size_bytes: 2048,
              type: "thread",
            },
          ],
        },
      ],
    },
  ],
}
