load("@bazel_skylib//lib:selects.bzl", "selects")
load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_library")
load("//pw_kernel:flags.bzl", "KERNEL_TEST_DEPS", "KERNEL_TEST_RUSTC_FLAGS")
load(":defs.bzl", "SUPPORTED_CORTEX_M_CPUS")

package(default_visibility = ["//visibility:public"])

rust_library(
    name = "arch_arm_cortex_m",
    srcs = [
        "exceptions.rs",
        "features.rs",
        "lib.rs",
        "nvic.rs",
        "protection/mod.rs",
        "protection/protection_v7.rs",
        "protection/protection_v8.rs",
        "regs.rs",
        "regs/mpu/mod.rs",
        "regs/mpu/mpu_v7.rs",
        "regs/mpu/mpu_v8.rs",
        "regs/msr.rs",
        "regs/nvic.rs",
        "regs/scb.rs",
        "regs/systick.rs",
        "spinlock.rs",
        "threads.rs",
        "timer.rs",
    ] + select({
        "//pw_kernel/userspace:userspace_build_enabled": ["syscall.rs"],
        "//conditions:default": [],
    }),
    crate_features = select({
        "//pw_kernel/userspace:userspace_build_enabled": ["user_space"],
        "//conditions:default": [],
    }) + selects.with_or({
        ("@platforms//cpu:armv7-m", "@platforms//cpu:armv7e-m"): ["armv7m"],
        "@platforms//cpu:armv8-m": ["armv8m"],
        "//conditions:default": [],
    }),
    edition = "2024",
    proc_macro_deps = [
        "//pw_kernel/macros:arm_cortex_m_macro",
        "@rust_crates//:paste",
    ],
    rustc_flags = KERNEL_TEST_RUSTC_FLAGS,
    tags = ["kernel"],
    target_compatible_with = selects.with_or({
        SUPPORTED_CORTEX_M_CPUS: [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    deps = [
        "//pw_kernel/config:kernel_config",
        "//pw_kernel/kernel",
        "//pw_kernel/lib/foreign_box",
        "//pw_kernel/lib/list",
        "//pw_kernel/lib/log_if",
        "//pw_kernel/lib/memory_config",
        "//pw_kernel/lib/pw_assert",
        "//pw_kernel/lib/pw_cast",
        "//pw_kernel/lib/regs",
        "//pw_kernel/lib/time",
        "//pw_kernel/syscall:exit_status",
        "//pw_status/rust:pw_status",
        "@pigweed//pw_log/rust:pw_log",
        "@rust_crates//:cortex-m",
        "@rust_crates//:cortex-m-rt",
    ] + select({
        "//pw_kernel/userspace:userspace_build_enabled": [
            "//pw_kernel/syscall:syscall_defs",
        ],
        "//conditions:default": [],
    }) + KERNEL_TEST_DEPS,
)

rust_doc(
    name = "arm_cortex_m_docs",
    crate = ":arch_arm_cortex_m",
    rustdoc_flags = [
        "--document-private-items",
        "--cfg=feature=\"arch_arm_cortex_m\"",
        # Document with ARMv8-M by default
        "--cfg=feature=\"armv8m\"",
    ] + select({
        "//pw_kernel/userspace:userspace_build_enabled": ["--cfg=feature=\"user_space\""],
        "//conditions:default": [],
    }),
    tags = ["kernel"],
)
