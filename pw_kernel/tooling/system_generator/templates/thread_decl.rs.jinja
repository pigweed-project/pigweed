{
    let (mut thread, _stack) = unsafe {
        kernel::declare_non_priv_thread!(
            "{{thread.name}}",
            {% if thread.priority %}
            kernel::Priority::{{ thread.priority }},
            {% else %}
            kernel::Priority::DEFAULT_PRIORITY,
            {% endif %}
            {# PROCESS_ID is declared by proces_decl.rs.jinja which invokes
                this template. #}
            PROCESS_ID,
            {{thread.stack_size_expression}}
        )
    };

    thread.object = Some(object_{{process.name | to_lower_ident}}_{{thread.name | to_lower_ident}}.clone());

    // Set thread object
    if let Err(_e) = object_{{process.name | to_lower_ident}}_{{thread.name | to_lower_ident}}.set_thread(arch::Arch, thread) {
        kernel::macro_exports::pw_assert::panic!("Failed to set thread object");
    }
}
