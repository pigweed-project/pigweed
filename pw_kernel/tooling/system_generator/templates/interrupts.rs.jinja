#[allow(unused_imports)]
use {{ arch_crate_name }} as arch;
#[allow(unused_imports)]
use foreign_box::ForeignRc;
#[allow(unused_imports)]
use kernel::interrupt_controller::{StaticContext, InterruptController, InterruptTableEntry};

type ArchInterruptTableEntry = InterruptTableEntry<<arch::Arch as kernel::Arch>::InterruptController>;

#[allow(unused_imports)]
{% if userspace %}
use kernel::object::InterruptObject;
{% endif %}
#[allow(unused_imports)]
use syscall_defs::Signals;

{% if userspace %}
{% for app in apps %}
    {% for process in app.processes %}
        {%- for object in process.objects %}
            {%- if object.type == "interrupt" %}
static {{object.object_ref_name}}: StaticContext<ForeignRc<<arch::Arch as kernel::Arch>::AtomicUsize, InterruptObject<arch::Arch>>> = StaticContext::new();
                {%- for irq in object.irqs %}
                    {%- set handler_name = object.handlers[irq.number] %}
                    {%- set mapped_signal = object.interrupt_signal_map[irq.name] %}
#[arch::interrupt]
extern "C" fn {{handler_name}}(from_userspace: bool) {
    if let Some(object) = unsafe { {{object.object_ref_name}}.get() } {
        let guard = kernel::interrupt_controller::InterruptGuard::new(arch::Arch, from_userspace);
        <arch::Arch as kernel::Arch>::InterruptController::userspace_interrupt_handler_enter(arch::Arch, {{irq.number}});
        object.interrupt(arch::Arch, {{mapped_signal}});
        <arch::Arch as kernel::Arch>::InterruptController::userspace_interrupt_handler_exit(arch::Arch, {{irq.number}}, guard);
    }
}
                {% endfor %}
            {%- endif -%}
        {%- endfor -%}
    {%- endfor -%}
{%- endfor %}
{% endif %}

{%- for irq in kernel.interrupt_table.table %}
unsafe extern "C" {
    {% if bare_interrupt_table_entries %}
    fn interrupt_handler_{{irq}}();
    {% else %}
    fn interrupt_handler_{{irq}}(from_userspace: bool);
    {% endif %}
}
{%- endfor %}

#[unsafe(no_mangle)]
{% if kernel.interrupt_table.link_section -%}
#[unsafe(link_section = "{{kernel.interrupt_table.link_section}}")]
{% endif -%}
// The interrupt table is a sparsely populated array, who's indexes correspond to the IRQ number of the handler.  The table size is the
// highest IRQ number + 1.
// On Cortex-M, the table starts after the exception entries in the vector table, as defined by the linker script.
static PW_KERNEL_INTERRUPT_TABLE_ARRAY: [ArchInterruptTableEntry; {{kernel.interrupt_table.table_size}}] = {
    #[allow(unused_mut)]
    let mut interrupt_table: [ArchInterruptTableEntry; {{kernel.interrupt_table.table_size}}] = [None; {{kernel.interrupt_table.table_size}}];
{%- for irq in kernel.interrupt_table.combined_ordered_table %}
    {%- set handler_name = kernel.interrupt_table.combined_ordered_table[irq] %}
    interrupt_table[{{irq}}] = Some({{handler_name}});
{%- endfor %}
    interrupt_table
};

#[unsafe(no_mangle)]
pub static PW_KERNEL_INTERRUPT_TABLE: &[ArchInterruptTableEntry] = &PW_KERNEL_INTERRUPT_TABLE_ARRAY;

// A macro is used to define the interrupt handler wrappers in the target crate, rather than codegen
// them directly.
// This allows the wrappers to call handler implementations that are defined in the target crate.
// Interrupt handler implementations are generic on the arch, so it's not possible to reference
// them through extern's.
#[macro_export]
macro_rules! declare_kernel_interrupt_handlers {
    () => {
        #[allow(unused_imports)]
        use {{ arch_crate_name }} as arch;
        #[allow(unused_imports)]
        use kernel::interrupt_controller::InterruptController;

        {%- for irq in kernel.interrupt_table.table %}
            {%- set handler_name = kernel.interrupt_table.table[irq] %}
        #[unsafe(no_mangle)]
        #[arch::interrupt]
        unsafe extern "C" fn interrupt_handler_{{irq}}(from_userspace: bool) {
            let guard = kernel::interrupt_controller::InterruptGuard::new(arch::Arch, from_userspace);
            <arch::Arch as kernel::Arch>::InterruptController::kernel_interrupt_handler_enter(arch::Arch, {{irq}});
            {{handler_name}}(arch::Arch);
            <arch::Arch as kernel::Arch>::InterruptController::kernel_interrupt_handler_exit(arch::Arch, {{irq}}, guard);
        }
        {%- endfor %}
    };
}
