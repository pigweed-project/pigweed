load("//pw_kernel/tooling:multi_process_app.bzl", "multi_process_app")
load("//pw_kernel/tooling:rust_process.bzl", "rust_process")

multi_process_app(
    name = "ipc",
    processes = [
        ":handler",
        ":initiator",
    ],
    tags = ["kernel"],
    visibility = ["//visibility:public"],
)

rust_process(
    name = "initiator",
    srcs = [
        "initiator.rs",
    ],
    codegen_crate_name = "initiator_codegen",
    edition = "2024",
    tags = ["kernel"],
    deps = [
        "//pw_kernel/lib/unittest:test_logger",
        "//pw_kernel/syscall:syscall_user",
        "//pw_kernel/userspace",
        "//pw_status/rust:pw_status",
    ],
)

rust_process(
    name = "handler",
    srcs = [
        "handler.rs",
    ],
    codegen_crate_name = "handler_codegen",
    edition = "2024",
    tags = ["kernel"],
    deps = [
        "//pw_kernel/lib/unittest:test_logger",
        "//pw_kernel/syscall:syscall_user",
        "//pw_kernel/userspace",
        "//pw_status/rust:pw_status",
    ],
)
