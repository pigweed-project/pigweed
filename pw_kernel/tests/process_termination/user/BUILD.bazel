load("@rules_rust//rust:defs.bzl", "rust_library")
load("//pw_kernel/tooling:multi_process_app.bzl", "multi_process_app")
load("//pw_kernel/tooling:rust_process.bzl", "rust_process")

multi_process_app(
    name = "process_termination",
    processes = [
        ":main",
        ":clean_exit",
        ":forced_exit",
        ":restart",
        ":exception_exit",
    ],
    tags = ["kernel"],
    visibility = ["//visibility:public"],
)

rust_process(
    name = "main",
    srcs = [
        "main.rs",
    ],
    codegen_crate_name = "main_codegen",
    edition = "2024",
    tags = ["kernel"],
    visibility = ["//visibility:public"],
    deps = [
        ":control_commands",
        "//pw_kernel/lib/time",
        "//pw_kernel/lib/unittest:test_logger",
        "//pw_kernel/syscall:syscall_user",
        "//pw_kernel/userspace",
        "//pw_status/rust:pw_status",
    ],
)

rust_process(
    name = "clean_exit",
    srcs = [
        "clean_exit.rs",
    ],
    codegen_crate_name = "clean_exit_codegen",
    edition = "2024",
    tags = ["kernel"],
    visibility = ["//visibility:public"],
    deps = [
        "//pw_kernel/lib/unittest:test_logger",
        "//pw_kernel/syscall:syscall_user",
        "//pw_kernel/userspace",
        "//pw_status/rust:pw_status",
    ],
)

rust_process(
    name = "forced_exit",
    srcs = [
        "forced_exit.rs",
    ],
    codegen_crate_name = "forced_exit_codegen",
    edition = "2024",
    tags = ["kernel"],
    visibility = ["//visibility:public"],
    deps = [
        "//pw_kernel/lib/unittest:test_logger",
        "//pw_kernel/syscall:syscall_user",
        "//pw_kernel/userspace",
        "//pw_status/rust:pw_status",
    ],
)

rust_process(
    name = "exception_exit",
    srcs = [
        "exception_exit.rs",
    ],
    codegen_crate_name = "exception_exit_codegen",
    edition = "2024",
    tags = ["kernel"],
    visibility = ["//visibility:public"],
    deps = [
        "//pw_kernel/lib/unittest:test_logger",
        "//pw_kernel/syscall:syscall_user",
        "//pw_kernel/userspace",
        "//pw_status/rust:pw_status",
    ],
)

rust_process(
    name = "restart",
    srcs = [
        "restart.rs",
    ],
    codegen_crate_name = "restart_codegen",
    edition = "2024",
    tags = ["kernel"],
    visibility = ["//visibility:public"],
    deps = [
        ":control_commands",
        "//pw_kernel/lib/unittest:test_logger",
        "//pw_kernel/syscall:syscall_user",
        "//pw_kernel/userspace",
        "//pw_status/rust:pw_status",
    ],
)

rust_library(
    name = "control_commands",
    srcs = ["control_commands.rs"],
    edition = "2024",
    tags = ["kernel"],
    visibility = ["//visibility:public"],
    deps = [
        "//pw_status/rust:pw_status",
    ],
)
