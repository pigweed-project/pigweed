load("//pw_kernel/tooling:multi_process_app.bzl", "multi_process_app")
load("//pw_kernel/tooling:rust_app.bzl", "rust_app")
load("//pw_kernel/tooling:rust_process.bzl", "rust_process")

multi_process_app(
    name = "handlers",
    processes = [
        ":handler1",
        ":handler2",
        ":handler3",
    ],
    tags = ["kernel"],
    visibility = ["//visibility:public"],
)

rust_process(
    name = "handler1",
    srcs = [
        "common_handler.rs",
        "handler1.rs",
    ],
    codegen_crate_name = "handler1_codegen",
    edition = "2024",
    tags = ["kernel"],
    deps = [
        "//pw_kernel/lib/unittest:test_logger",
        "//pw_kernel/userspace",
        "//pw_status/rust:pw_status",
    ],
)

rust_process(
    name = "handler2",
    srcs = [
        "common_handler.rs",
        "handler2.rs",
    ],
    codegen_crate_name = "handler2_codegen",
    edition = "2024",
    tags = ["kernel"],
    deps = [
        "//pw_kernel/lib/unittest:test_logger",
        "//pw_kernel/userspace",
        "//pw_status/rust:pw_status",
    ],
)

rust_process(
    name = "handler3",
    srcs = [
        "common_handler.rs",
        "handler3.rs",
    ],
    codegen_crate_name = "handler3_codegen",
    edition = "2024",
    tags = ["kernel"],
    deps = [
        "//pw_kernel/lib/unittest:test_logger",
        "//pw_kernel/userspace",
        "//pw_status/rust:pw_status",
    ],
)

rust_app(
    name = "initiator",
    srcs = ["initiator.rs"],
    codegen_crate_name = "initiator_codegen",
    edition = "2024",
    tags = ["kernel"],
    visibility = ["//visibility:public"],
    deps = [
        "//pw_kernel/lib/time",
        "//pw_kernel/lib/unittest:test_logger",
        "//pw_kernel/userspace",
        "//pw_status/rust:pw_status",
    ],
)
