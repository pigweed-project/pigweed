# Options required to compile picotool and pioasm with exceptions enabled
common --per_file_copt=external.*picotool.*@-fexceptions,-frtti
common --host_per_file_copt=external.*picotool.*@-fexceptions,-frtti
common --host_per_file_copt=external.*pioasm.*@-fexceptions,-frtti

# Ignore warnings in external dependencies
common --per_file_copt=external/.*@-w
common --host_per_file_copt=external/.*@-w

# Force hard-float ABI globally for target compilation to match Rust compiler
build --per_file_copt=external/pigweed.*/.*,external/zephyr.*/.*,external/hal_rpi_pico.*/.*,external/cmsis_6.*/.*,app/.*,boards/.*@-mfloat-abi=hard
build --@rules_rust//:extra_rustc_flags=-Clink-arg=-mfloat-abi=hard

# Configure Pigweed platform deps and rust logging backend
build --@pigweed//targets/pw_rp2350:platform_deps=//app:boot
build --@pigweed//pw_assert:assert_backend=@pigweed//pw_assert_trap:assert_backend
build --@pigweed//pw_assert:assert_backend_impl=@pigweed//pw_assert_trap:impl
build --@pigweed//pw_assert:check_backend=@pigweed//pw_assert_trap:check_backend
build --@pigweed//pw_assert:check_backend_impl=@pigweed//pw_assert_trap:impl
build --@pigweed//pw_log/rust:pw_log_backend=@pigweed//targets/pw_rp2350:rust_log_basic_backend
build --@pigweed//pw_log:backend=@pigweed//pw_log_basic
build --@pigweed//pw_log:backend_impl=@pigweed//pw_log_basic:impl
build --@pigweed//pw_sync:interrupt_spin_lock_backend=@pigweed//pw_sync_baremetal:interrupt_spin_lock
build --@pigweed//pw_sys_io:backend=@pigweed//pw_sys_io_zephyr:backend
