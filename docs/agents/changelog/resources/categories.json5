      "pw_span",
      "pw_string",
      "pw_preprocessor",
      "pw_result",
      "pw_status",
    ]
  },
  crypto: {
    title: "Cryptography and security",
    show: true,
    modules: [
      "pw_crypto",
      "pw_random",
      "pw_random_fuchsia",
      "pw_tls_client_boringssl",
      "pw_tls_client_mbedtls",
    ]
  },
  data: {
    title: "Data encoding and serialization",
    show: true,
    modules: [
      "pw_base64",
