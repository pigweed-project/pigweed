// This file provides the category definitions that AI agents must follow
// when creating a changelog update. The top-level keys are the valid category
// IDs.
//
// Explanation of fields:
//
// * `title` - The title for the category that will be used in the published changelog.
//
// * `show` - Agents can ignore this value.
//
// * `modules` - Pigweed modules related to the category.
//
// * `files` - Unix-style pathname patterns related to the category.
{
  arch: {
    title: "Arch interfaces",
    show: true,
    modules: [
      "pw_boot",
      "pw_boot_cortex_m",
      "pw_cpu_exception",
      "pw_cpu_exception_cortex_m",
      "pw_cpu_exception_risc_v",
      "pw_interrupt",
      "pw_interrupt_cortex_m",
      "pw_interrupt_freertos",
      "pw_interrupt_zephyr",
    ]
  },
  async: {
    title: "Async and concurrency",
    show: true,
    modules: [
      "pw_async",
      "pw_async2",
      "pw_async_basic",
      "pw_async_fuchsia",
      "pw_atomic",
      "pw_sync",
      "pw_sync_baremetal",
      "pw_sync_embos",
      "pw_sync_freertos",
      "pw_sync_stl",
      "pw_sync_threadx",
      "pw_sync_zephyr",
      "pw_thread",
      "pw_thread_embos",
      "pw_thread_freertos",
      "pw_thread_stl",
      "pw_thread_threadx",
      "pw_thread_zephyr",
      "pw_work_queue",
    ]
  },
  build: {
    title: "Build systems",
    show: true,
    modules: [
      "pw_arduino_build",
      "pw_build",
      "pw_build_android",
      "pw_build_info",
      "pw_build_mcuxpresso",
      "pw_stm32cube_build",
    ]
  },
  cpp: {
