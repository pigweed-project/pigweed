import("//build_overrides/pigweed.gni")

import("$dir_pw_build/target_types.gni")
import("$dir_pw_third_party/freertos/freertos.gni")

pw_source_set("freertos_sys_header") {
  public = [ "freertos_sys.h" ]
  sources = [ "freertos_sys.c" ]
  public_configs = [ "//third_party/freertos:public_include_path" ]
  public_deps = [ "//third_party/freertos:config_assert" ]
  if (dir_pw_third_party_freertos != "") {
    public_deps += [ "$pw_external_freertos" ]
  }
}

pw_rust_bindgen("freertos_sys_bindgen") {
  header = "freertos_sys.h"
  flags = [
    "--rust-edition",
    "2021",
    "--use-core",
  ]
  deps = [ ":freertos_sys_header" ]
}

pw_rust_library("freertos_sys") {
  sources = [ "lib.rs" ]
  bindgen_output = get_target_outputs(":freertos_sys_bindgen")
  rustenv = [ "BINDGEN_RS_FILE=" + rebase_path(bindgen_output[0]) ]
  rustflags = [ "--cfg=rust_bindgen_include" ]
  deps = [
    ":freertos_sys_bindgen",
    ":freertos_sys_header",
  ]
}
