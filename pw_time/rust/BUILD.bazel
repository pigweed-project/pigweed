load("@pigweed//pw_build:compatibility.bzl", "incompatible_with_mcu")
load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test", "rust_library", "rust_test")
load("@zephyr//:cc.bzl", "zephyr_cc_library")

package(default_visibility = ["//visibility:public"])

rust_library(
    name = "pw_time_core",
    srcs = [
        "pw_time_core.rs",
    ],
    edition = "2021",
    deps = [
        "//pw_assert/rust:pw_assert",
    ],
)

rust_doc(
    name = "pw_time_core_doc",
    crate = ":pw_time_core",
    target_compatible_with = incompatible_with_mcu(),
)

rust_doc_test(
    name = "pw_time_core_doc_test",
    crate = ":pw_time_core",
    target_compatible_with = incompatible_with_mcu(),
)

rust_test(
    name = "pw_time_core_test",
    crate = ":pw_time_core",
    target_compatible_with = incompatible_with_mcu(),
)

rust_library(
    name = "pw_time",
    srcs = [
        "pw_time.rs",
    ],
    crate_name = "pw_time",
    edition = "2021",
    deps = [
        ":pw_time_backend",
        ":pw_time_core",
        "//pw_assert/rust:pw_assert",
    ],
)

rust_library(
    name = "pw_time_backend_std",
    srcs = [
        "pw_time_backend_std.rs",
    ],
    crate_name = "pw_time_backend",
    edition = "2021",
    target_compatible_with = incompatible_with_mcu(),
    deps = [
        ":pw_time_core",
        "//pw_assert/rust:pw_assert",
    ],
)

rust_library(
    name = "pw_time_backend_freertos",
    srcs = [
        "pw_time_backend_freertos.rs",
    ],
    crate_name = "pw_time_backend",
    edition = "2021",
    target_compatible_with = ["//pw_build/constraints/rtos:freertos"],
    deps = [
        ":pw_time_core",
        "//pw_sync/rust/pw_sync_spinlock",
        "//third_party/freertos/freertos_sys",
    ],
)

rust_library(
    name = "pw_time_backend_pigweed",
    srcs = [
        "pw_time_backend_pigweed.rs",
    ],
    aliases = {
        "//pw_kernel/target:target_arch": "target_arch",
    },
    crate_name = "pw_time_backend",
    edition = "2021",
    target_compatible_with = ["//pw_build/constraints/rtos:pigweed"],
    deps = [
        ":pw_time_core",
        "//pw_kernel/config:kernel_config",
        "//pw_kernel/kernel",
        "//pw_kernel/target:target_arch",
    ],
)

rust_library(
    name = "pw_time_backend_zephyr",
    srcs = [
        "pw_time_backend_zephyr.rs",
    ],
    crate_name = "pw_time_backend",
    edition = "2021",
    target_compatible_with = ["//pw_build/constraints/rtos:zephyr"],
    deps = [
        ":pw_time_backend_zephyr_helper",
        ":pw_time_core",
    ],
)

zephyr_cc_library(
    name = "pw_time_backend_zephyr_helper",
    srcs = ["pw_time_backend_zephyr_helper.cc"],
    target_compatible_with = ["//pw_build/constraints/rtos:zephyr"],
    deps = [
        "@zephyr//:board_deps",
    ],
)

label_flag(
    name = "pw_time_backend",
    build_setting_default = ":pw_time_backend_std",
    visibility = ["//visibility:public"],
)

rust_doc(
    name = "pw_time_doc",
    crate = ":pw_time",
    target_compatible_with = incompatible_with_mcu(),
)

rust_doc_test(
    name = "pw_time_doc_test",
    crate = ":pw_time",
    target_compatible_with = incompatible_with_mcu(),
)
